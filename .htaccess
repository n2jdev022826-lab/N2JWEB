RewriteEngine On

# 1. Serve landing page when root is accessed
DirectoryIndex front-end/landing-page.html

# 2. Exclude actual files and folders (CSS/JS/images)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Redirect all other requests to front-end folder
RewriteRule ^(.*)$ front-end/$1 [L]